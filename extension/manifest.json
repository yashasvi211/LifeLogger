{
    "manifest_version": 3,
    "name": "LifeLogger",
    "version": "0.1.0",
    "description": "Tracks browser tab activity and sends logs to the local LifeLogger daemon.",
    "permissions": [
        "tabs",
        "idle",
        "alarms"
    ],
    "host_permissions": [
        "http://localhost:7777/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}